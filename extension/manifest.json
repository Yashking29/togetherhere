{
  "manifest_version": 3,
  "name": "Together — Watch Party",
  "short_name": "Together",
  "version": "1.0.0",
  "description": "Watch Netflix, Prime Video, Disney+ and more in perfect sync with your partner.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "*://*.netflix.com/*",
    "*://*.primevideo.com/*",
    "*://*.amazon.com/*",
    "*://*.disneyplus.com/*",
    "*://*.hotstar.com/*",
    "*://*.hulu.com/*",
    "https://togetherhere.online/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.netflix.com/*",
        "*://*.primevideo.com/*",
        "*://*.amazon.com/*",
        "*://*.disneyplus.com/*",
        "*://*.hotstar.com/*",
        "*://*.hulu.com/*"
      ],
      "js": ["socket.io.min.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": {
    "16":  "icons/icon-16.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
